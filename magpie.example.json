{
  "modes": {
    "plan": {
      "statusLabel": "plan",
      "skills": ["planning"]
    },
    "pa": {
      "statusLabel": "pa",
      "tools": [
        "calendar_upcoming",
        "calendar_get_event",
        "calendar_create_event",
        "email_search",
        "email_list_unread",
        "email_fetch",
        "email_save_draft"
      ],
      "hideTools": ["edit", "write"]
    }
  },
  "delegate": {
    "model": "provider/model-id",
    "thinkingLevel": "medium"
  },
  "handoff": {
    "defaultMode": "default"
  },
  "sessions": {
    "autoIndex": true,
    "maxIndexEntries": 500
  },
  "commit": {},
  "btw": {},
  "web": {
    "searchTimeout": 120000,
    "fetchTimeout": 30000
  },
  "preferences": {
    "enabled": true
  },
  "memory": {
    "rootDir": "~/.pi/agent/memory",
    "autodream": {
      "enabled": false
    }
  },
  "personalAssistant": {
    "timezone": "Europe/Amsterdam",
    "storageDir": "~/.pi/agent/personal-assistant"
  },
  "schedule": {
    "notifier": "macos"
  },
  "webui": {
    "enabled": false,
    "port": 8765,
    "bind": "localhost"
  }
}
